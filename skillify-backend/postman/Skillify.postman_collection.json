{
  "info": {
    "name": "Skillify API",
    "description": "REST API collection for the Skillify learning platform backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "courseId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Singh\",\n  \"email\": \"priya@skillify.dev\",\n  \"password\": \"password123\",\n  \"role\": \"student\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"priya@skillify.dev\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get All Courses",
          "request": { "method": "GET", "url": "{{baseUrl}}/courses" }
        },
        {
          "name": "Get Course By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/courses/{{courseId}}" }
        },
        {
          "name": "Create Course (instructor)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/courses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"React for Beginners\",\n  \"description\": \"Learn React from scratch.\",\n  \"category\": \"Web Development\",\n  \"level\": \"Beginner\",\n  \"price\": 499\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "Enroll in Course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/enrollments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course\": \"{{courseId}}\"\n}"
            }
          }
        },
        {
          "name": "My Courses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/enrollments/my-courses"
          }
        }
      ]
    }
  ]
}
